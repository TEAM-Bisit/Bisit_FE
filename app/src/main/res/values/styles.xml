<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="BottomNavLabelStyle">
        <item name="android:textSize">11sp</item>
    </style>

    <style name="Widget.App.BottomNavigationView" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemPaddingTop">4dp</item> <item name="itemPaddingBottom">4dp</item> </style>

    <style name="CustomRadioButton" parent="Widget.AppCompat.CompoundButton.RadioButton">
        <item name="buttonTint">@null</item>
        <item name="android:button">@drawable/selector_radio_button_icon</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:textColor">#222222</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">-0.025</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:background">@android:color/transparent</item>
    </style>

</resources>