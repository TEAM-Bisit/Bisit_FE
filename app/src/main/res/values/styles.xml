<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="BottomNavLabelStyle">
        <item name="android:textSize">11sp</item>
    </style>

    <style name="Widget.App.BottomNavigationView" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemPaddingTop">4dp</item>
        <item name="itemPaddingBottom">4dp</item>
    </style>

    <style name="CustomRadioButton" parent="Widget.AppCompat.CompoundButton.RadioButton">
        <item name="buttonTint">@null</item>
        <item name="android:button">@drawable/selector_radio_button_icon</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:textColor">#222222</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">-0.025</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="CustomShopRadioButton" parent="Widget.AppCompat.CompoundButton.RadioButton">
        <item name="buttonTint">@null</item>
        <item name="android:button">@drawable/selector_radio_button_icon</item>
        <item name="android:paddingStart">6dp</item>
        <item name="android:textColor">#222222</item>
        <item name="android:textSize">14sp</item>
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="TimeSlotButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:background">@drawable/bg_time_slot</item>
        <item name="android:textColor">#222222</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="CustomBottomSheetTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/CustomShapeAppearanceBottomSheet</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>

    <style name="CustomShapeAppearanceBottomSheet" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="backgroundTint">#FEFEFE</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.BottomSheet.RoundedTop</item>
    </style>

    <style name="ShapeAppearanceOverlay.BottomSheet.RoundedTop" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">12dp</item>
        <item name="cornerSizeTopRight">12dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="TabTextAppearance" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">16sp</item>
    </style>

    <style name="TopRoundedCard" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeTopRight">16dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

</resources>
