<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.Bisit" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorControlHighlight">#1FFFFFFF</item>
        <!-- 윈도우 배경 흰색 -->
        <item name="android:windowBackground">@android:color/white</item>
        <item name="popupMenuStyle">@style/MyPopupMenuStyle</item>
        <!-- 상태바 배경 흰색 -->
        <item name="android:statusBarColor">@android:color/white</item>
        <!-- 상태바 아이콘 어둡게 (API 23+) -->
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    </style>

    <style name="Theme.Bisit" parent="Base.Theme.Bisit" />

    <style name="Theme.Splash" parent="Base.Theme.Bisit">
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="MyPopupMenuStyle" parent="Widget.AppCompat.PopupMenu">
        <item name="android:popupBackground">@drawable/bg_day_selection_selector</item>
    </style>

    <style name="Theme.Bisit.Main" parent="Theme.Bisit">
        <item name="android:windowDisablePreview">true</item>
    </style>

    <!-- Clean DatePicker Theme (Minimalist) -->
    <style name="DatePickerTheme" parent="Theme.MaterialComponents.Light.Dialog">
        <item name="colorAccent">#222222</item>
        <item name="android:windowBackground">@drawable/bg_dialog_white</item>
        <item name="android:headerBackground">#FFFFFF</item>
        <item name="android:colorPrimary">#222222</item>
        <item name="android:headerTextColor">#222222</item>
    </style>
</resources>