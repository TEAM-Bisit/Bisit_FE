<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/stepper_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="18dp"
    android:paddingEnd="18dp"
    android:paddingTop="14dp"
    android:paddingBottom="14dp">

    <TextView
        android:id="@+id/step1_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="사업자 등록"
        android:textColor="@color/stepper_text_active"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/step2_text"
        app:layout_constraintHorizontal_chainStyle="spread_inside"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/step2_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="매장 등록"
        android:textColor="@color/stepper_text_inactive"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@id/step1_text"
        app:layout_constraintEnd_toStartOf="@+id/step3_text"
        app:layout_constraintStart_toEndOf="@+id/step1_text"
        app:layout_constraintTop_toTopOf="@id/step1_text" />

    <TextView
        android:id="@+id/step3_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="매장 소개"
        android:textColor="@color/stepper_text_inactive"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@id/step1_text"
        app:layout_constraintEnd_toStartOf="@+id/step4_text"
        app:layout_constraintStart_toEndOf="@+id/step2_text"
        app:layout_constraintTop_toTopOf="@id/step1_text" />

    <TextView
        android:id="@+id/step4_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="업종 등록"
        android:textColor="@color/stepper_text_inactive"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@id/step1_text"
        app:layout_constraintEnd_toStartOf="@+id/step5_text"
        app:layout_constraintStart_toEndOf="@+id/step3_text"
        app:layout_constraintTop_toTopOf="@id/step1_text" />

    <TextView
        android:id="@+id/step5_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="운영 시간"
        android:textColor="@color/stepper_text_inactive"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@id/step1_text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/step4_text"
        app:layout_constraintTop_toTopOf="@id/step1_text" />

    <View
        android:id="@+id/stepper_line"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:background="@color/stepper_line_color"
        app:layout_constraintBottom_toBottomOf="@id/step1_icon"
        app:layout_constraintEnd_toEndOf="@id/step5_icon"
        app:layout_constraintStart_toStartOf="@id/step1_icon"
        app:layout_constraintTop_toTopOf="@id/step1_icon" />

    <ImageView
        android:id="@+id/step1_icon"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginBottom="8dp"
        android:src="@drawable/stepper_circle_active"
        app:layout_constraintBottom_toTopOf="@id/step1_text"
        app:layout_constraintEnd_toEndOf="@+id/step1_text"
        app:layout_constraintStart_toStartOf="@+id/step1_text"
        tools:ignore="ContentDescription" />

    <ImageView
        android:id="@+id/step2_icon"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:src="@drawable/stepper_circle_inactive"
        app:layout_constraintBottom_toBottomOf="@id/step1_icon"
        app:layout_constraintEnd_toEndOf="@+id/step2_text"
        app:layout_constraintStart_toStartOf="@+id/step2_text"
        app:layout_constraintTop_toTopOf="@id/step1_icon"
        tools:ignore="ContentDescription" />

    <ImageView
        android:id="@+id/step3_icon"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:src="@drawable/stepper_circle_inactive"
        app:layout_constraintBottom_toBottomOf="@id/step1_icon"
        app:layout_constraintEnd_toEndOf="@+id/step3_text"
        app:layout_constraintStart_toStartOf="@+id/step3_text"
        app:layout_constraintTop_toTopOf="@id/step1_icon"
        tools:ignore="ContentDescription" />

    <ImageView
        android:id="@+id/step4_icon"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:src="@drawable/stepper_circle_inactive"
        app:layout_constraintBottom_toBottomOf="@id/step1_icon"
        app:layout_constraintEnd_toEndOf="@+id/step4_text"
        app:layout_constraintStart_toStartOf="@+id/step4_text"
        app:layout_constraintTop_toTopOf="@id/step1_icon"
        tools:ignore="ContentDescription" />

    <ImageView
        android:id="@+id/step5_icon"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:src="@drawable/stepper_circle_inactive"
        app:layout_constraintBottom_toBottomOf="@id/step1_icon"
        app:layout_constraintEnd_toEndOf="@+id/step5_text"
        app:layout_constraintStart_toStartOf="@+id/step5_text"
        app:layout_constraintTop_toTopOf="@id/step1_icon"
        tools:ignore="ContentDescription" />

</androidx.constraintlayout.widget.ConstraintLayout>