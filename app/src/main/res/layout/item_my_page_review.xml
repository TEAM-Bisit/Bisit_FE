<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    card:cardCornerRadius="12dp"
    card:cardElevation="4dp"
    android:layout_marginBottom="12dp"
    android:foreground="?android:attr/selectableItemBackground">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <FrameLayout
            android:id="@+id/layout_more_area"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true">

            <ImageButton
                android:id="@+id/btn_more"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_dot3"
                android:contentDescription="더보기" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2025.09.12.금 방문"
            android:textSize="13sp"
            android:textColor="#6D7583" />

        <LinearLayout
            android:id="@+id/layout_service"
            android:layout_below="@id/tv_date"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tv_service_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="서비스명"
                android:textStyle="bold"
                android:textColor="#515965"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tv_service_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="매니큐어"
                android:textSize="14sp"
                android:textColor="#222222" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_stars"
            android:layout_below="@id/layout_service"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tv_star_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="별점"
                android:textStyle="bold"
                android:textColor="#515965"
                android:textSize="13sp"
                android:layout_marginEnd="30dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="8dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_home_star"
                    android:layout_marginHorizontal="2dp" />
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_home_star"
                    android:layout_marginHorizontal="2dp" />
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_home_star"
                    android:layout_marginHorizontal="2dp" />
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_home_star"
                    android:layout_marginHorizontal="2dp" />
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_home_star"
                    android:layout_marginHorizontal="2dp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_content"
            android:layout_below="@id/layout_stars"
            android:layout_marginTop="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="마음에 쏙 들어요! 선생님도 친절하셔서 기분 좋게 시술 받았습니다^^"
            android:textColor="#222222"
            android:textSize="13sp"
            android:layout_toStartOf="@id/layout_more_area"/>
    </RelativeLayout>
</androidx.cardview.widget.CardView>
