<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Scrollable Content Area -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnMap">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <!-- Top Area -->
            <RelativeLayout
                android:id="@+id/topArea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:layout_marginTop="32dp">

                <ImageView
                    android:id="@+id/imgLogo"
                    android:layout_width="65dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_category_logo"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"/>

                <ImageView
                    android:id="@+id/imgAlarm"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_alarm"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>

            <!-- Location Area -->
            <LinearLayout
                android:id="@+id/locationArea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="20dp"
                android:paddingHorizontal="20dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_category_region" />

                <TextView
                    android:id="@+id/tvLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="대구 중구 관덕정길 6-11 1층"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#292929"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- Banner Section -->
            <FrameLayout
                android:id="@+id/layoutBanner"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginTop="24dp"
                android:layout_marginHorizontal="20dp"
                android:background="@drawable/bg_category_banner">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="손 쉬운 방문 서비스 예약은"
                        android:textColor="#515965"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="비짓에서"
                        android:textColor="#222222"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="90dp"
                    android:layout_height="70dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/img_category_header"
                    android:scaleType="fitCenter"/>
            </FrameLayout>

            <!-- Category Layout (Grid 2x4) -->
            <TableLayout
                android:id="@+id/categoryLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:paddingHorizontal="20dp"
                android:stretchColumns="0,1,2,3">

                <TableRow android:layout_marginBottom="24dp">
                    <LinearLayout
                        android:id="@+id/category_home"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView android:layout_width="56dp" android:layout_height="56dp" android:src="@drawable/ic_category_home" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="생활가정" android:textSize="13sp" android:textColor="#222222" android:layout_marginTop="8dp" />
                    </LinearLayout>
                    <LinearLayout android:id="@+id/category_it" android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                        <ImageView android:layout_width="56dp" android:layout_height="56dp" android:src="@drawable/ic_category_it" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="IT·전자기기" android:textSize="13sp" android:textColor="#222222" android:layout_marginTop="8dp" />
                    </LinearLayout>
                    <LinearLayout android:id="@+id/category_fix" android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                        <ImageView android:layout_width="56dp" android:layout_height="56dp" android:src="@drawable/ic_category_fix" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="수리·설치" android:textSize="13sp" android:textColor="#222222" android:layout_marginTop="8dp" />
                    </LinearLayout>
                    <LinearLayout android:id="@+id/category_car" android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                        <ImageView android:layout_width="56dp" android:layout_height="56dp" android:src="@drawable/ic_category_car" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="차량 관리" android:textSize="13sp" android:textColor="#222222" android:layout_marginTop="8dp" />
                    </LinearLayout>
                </TableRow>

                <TableRow>
                    <LinearLayout android:id="@+id/category_health" android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                        <ImageView android:layout_width="56dp" android:layout_height="56dp" android:src="@drawable/ic_category_health" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="헬스케어" android:textSize="13sp" android:textColor="#222222" android:layout_marginTop="8dp" />
                    </LinearLayout>
                    <LinearLayout android:id="@+id/category_office" android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                        <ImageView android:layout_width="56dp" android:layout_height="56dp" android:src="@drawable/ic_category_office" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="오피스 관리" android:textSize="13sp" android:textColor="#222222" android:layout_marginTop="8dp" />
                    </LinearLayout>
                    <LinearLayout android:id="@+id/category_camera" android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                        <ImageView android:layout_width="56dp" android:layout_height="56dp" android:src="@drawable/ic_category_camera" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="촬영·행사" android:textSize="13sp" android:textColor="#222222" android:layout_marginTop="8dp" />
                    </LinearLayout>
                    <LinearLayout android:id="@+id/category_edu" android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                        <ImageView android:layout_width="56dp" android:layout_height="56dp" android:src="@drawable/ic_category_edu" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="학습·교육" android:textSize="13sp" android:textColor="#222222" android:layout_marginTop="8dp" />
                    </LinearLayout>
                </TableRow>
            </TableLayout>

            <View
                android:id="@+id/divider"
                android:layout_width="120dp"
                android:layout_height="1dp"
                android:layout_marginTop="48dp"
                android:background="#E1E4E8"
                android:layout_gravity="center_horizontal" />

            <!-- Guide Section (Card) -->
            <FrameLayout
                android:id="@+id/layoutGuide"
                android:layout_width="match_parent"
                android:layout_height="134dp"
                android:layout_marginTop="24dp"
                android:layout_marginHorizontal="20dp"
                android:background="@drawable/bg_category_guide_card">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="처음 사용해보시나요?"
                        android:textColor="#222222"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="사용 가이드 읽기"
                        android:textColor="#515965"
                        android:textSize="14sp"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="140dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="end"
                    android:layout_marginEnd="0dp"
                    android:src="@drawable/img_category_foot"
                    android:scaleType="centerInside"/>
            </FrameLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Sticky Footer Button -->
    <LinearLayout
        android:id="@+id/btnMap"
        android:layout_width="120dp"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bg_list"
        android:layout_marginBottom="20dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_map" />

        <TextView
            android:id="@+id/tv_map"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="지도 보기"
            android:textColor="#515965"
            android:textSize="14sp"
            android:layout_marginStart="8dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
