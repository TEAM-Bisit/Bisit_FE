<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <!-- 상단 흰색 영역 (고정) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:paddingHorizontal="18dp"
        android:paddingTop="39dp"
        android:paddingBottom="8dp"
        android:elevation="2dp">

        <!-- 제목 -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="예약 내역"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#222222" />

        <!-- 검색 + 달력 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical">

            <!-- 검색창 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_search_box"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:src="@drawable/ic_search"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginEnd="8dp" />

                <EditText
                    android:id="@+id/etSearch"
                    android:hint="예약자명을 검색해보세요"
                    android:minHeight="52dp"
                    android:textSize="15sp"
                    android:textColor="#222222"
                    android:textColorHint="#9AA1AF"
                    android:background="@null"
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- 달력 버튼 -->
            <LinearLayout
                android:id="@+id/btnCalendar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="4dp"
                android:gravity="center"
                android:background="@drawable/bg_calendar_circle">

                <ImageView
                    android:src="@drawable/ic_today_reserv"
                    android:layout_width="24dp"
                    android:layout_height="24dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 정렬 버튼 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAscending"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="0dp"
                android:minWidth="0dp"
                app:iconPadding="0dp"
                app:contentPaddingLeft="12dp"
                app:contentPaddingRight="12dp"
                app:contentPaddingTop="6dp"
                app:contentPaddingBottom="6dp"
                android:text="오름차순"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_order_active"
                android:backgroundTint="@null"
                app:backgroundTint="@null"
                app:rippleColor="@android:color/transparent"
                tools:ignore="TouchTargetSizeCheck" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDescending"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="0dp"
                android:minWidth="0dp"
                app:iconPadding="0dp"
                app:contentPaddingLeft="12dp"
                app:contentPaddingRight="12dp"
                app:contentPaddingTop="6dp"
                app:contentPaddingBottom="6dp"
                android:layout_marginStart="6dp"
                android:text="내림차순"
                android:textColor="#515965"
                android:background="@drawable/bg_order_inactive"
                android:backgroundTint="@null"
                app:backgroundTint="@null"
                app:rippleColor="@android:color/transparent"
                tools:ignore="TouchTargetSizeCheck" />
        </LinearLayout>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvReservations"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginHorizontal="18dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingBottom="20dp"
        tools:listitem="@layout/item_reserv_list" />

</LinearLayout>
