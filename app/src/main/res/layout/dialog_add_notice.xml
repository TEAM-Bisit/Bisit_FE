<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_white"
    android:padding="16dp">

    <!-- 타이틀 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/notice_add_title"
            android:textColor="#222222"
            android:textStyle="bold"
            android:textSize="16sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/btnClose"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_close_button"
            android:contentDescription="닫기" />
    </LinearLayout>

    <!-- 제목 라벨 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:layout_marginBottom="8dp"
        android:text="@string/notice_title_label"
        android:textColor="#515965"
        android:textStyle="bold"
        android:textSize="14sp" />

    <!-- 제목 입력 + 카운트 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <EditText
            android:id="@+id/etTitle"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="@string/notice_title_hint"
            android:paddingHorizontal="12dp"
            android:inputType="text"
            android:maxLength="30"
            android:scrollHorizontally="true"
            android:importantForAutofill="no"
            android:textColor="#222222"
            android:textColorHint="#9AA1AF"
            android:textSize="14sp"
            android:background="@drawable/bg_edit_box" />

        <TextView
            android:id="@+id/tvTitleCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="12dp"
            android:text="@string/notice_title_count_default"
            android:textSize="12sp"
            android:textColor="#9AA1AF" />
    </RelativeLayout>

    <!-- 내용 라벨 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="8dp"
        android:text="@string/notice_content_label"
        android:textColor="#515965"
        android:textStyle="bold"
        android:textSize="14sp" />

    <!-- 내용 입력 + 카운트 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <EditText
            android:id="@+id/etContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="4"
            android:gravity="top"
            android:hint="@string/notice_content_hint"
            android:padding="12dp"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLength="50"
            android:scrollHorizontally="false"
            android:importantForAutofill="no"
            android:textColor="#222222"
            android:textColorHint="#9AA1AF"
            android:textSize="14sp"
            android:background="@drawable/bg_edit_box" />

        <TextView
            android:id="@+id/tvContentCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignBottom="@id/etContent"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="8dp"
            android:text="@string/notice_content_count_default"
            android:textSize="12sp"
            android:textColor="#9AA1AF" />
    </RelativeLayout>

    <!-- 등록 버튼 -->
    <TextView
        android:id="@+id/btnSubmit"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="@string/notice_submit"
        android:textStyle="bold"
        android:textColor="@color/btn_primary_text_selector"
        android:background="@drawable/bg_btn_primary_selector" />

</LinearLayout>
