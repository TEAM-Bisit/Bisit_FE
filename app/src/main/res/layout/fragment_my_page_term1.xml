<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_term1"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:layout_marginTop="24dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="이용약관"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EAEAEA" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/term1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="제 1조 목적"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"/>

            <TextView
                android:id="@+id/term1_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="본 약관은 'Bisit'(이하 '회사')가 제공하는 서비스('이하 서비스')의 \n이용조건 및 절차, 회사와 회원의 권리,의무를 규정함을 목적으 합니\n다."
                android:textColor="#6D7583"
                android:textSize="12sp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:id="@+id/term1_title2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="제 2조 회원가입"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"/>

            <TextView
                android:id="@+id/term1_content2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="회원은 회사가 정한 절차에 따라 가입하며, 허위 정보를 기재할 경우 서\n비스 이용이 제한될 수 있습니다."
                android:textColor="#6D7583"
                android:textSize="12sp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:id="@+id/term1_title3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="제 3조 서비스 이용"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"/>

            <TextView
                android:id="@+id/term1_content3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="회사는 회원에게 예약, 결제, 위치 기반 매칭 등 서비스를 제공합니다. \n단, 서비스 내용은 회사 사정에 따라 변경될 수 있습니다."
                android:textColor="#6D7583"
                android:textSize="12sp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:id="@+id/term1_title4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="제 4조 금지행위"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"/>

            <TextView
                android:id="@+id/term1_content4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="① 타인의 정보 도용, 허위 예약, 법령 위반 행위는 금지됩니다.\n② 회원은 회사가 제공하는 결제 시스템을 우회하여, 회사의 수수료를\n회피하기 위한 행위를 해서는 안 됩니다.\n③ 사장님(제휴 매장 포함)은 회원에게 회사 서비스 외부 결제를 유도\n하거나, 외부 계좌이체를 권유할 수 없습니다."
                android:textColor="#6D7583"
                android:textSize="12sp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:id="@+id/term1_title5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="제 5조 예약 및 결제"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"/>

            <TextView
                android:id="@+id/term1_content5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="① 모든 예약은 회사가 제공하는 결제 시스템을 통해 사전 결제를 완료\n해야만 확정됩니다.\n② 결제 완료 전 상태의 예약은 확정되지 않으며, 지정된 시간 내 결제\n가 이루어지지 않을 경우 자동 취소됩니다.\n③ 회사는 회원과 사장님 간 거래의 안전을 보장하기 위하여 결제 대금\n을 일정 기간 보관(에스크로) 후 정산합니다."
                android:textColor="#6D7583"
                android:textSize="12sp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:id="@+id/term1_title6"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="제 6조 취소 및 환불"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"/>

            <TextView
                android:id="@+id/term1_content6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="본 약관은 'Bisit'(이하 '회사')가 제공하는 서비스('이하 서비스')의 \n이용조건 및 절차, 회사와 회원의 권리,의무를 규정함을 목적으 합니\n다."
                android:textColor="#6D7583"
                android:textSize="12sp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"/>
        </LinearLayout>

    </ScrollView>

</LinearLayout>
