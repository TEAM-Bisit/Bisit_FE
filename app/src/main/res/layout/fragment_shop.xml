<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/coordinatorLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/appBarLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fitsSystemWindows="true"
            android:background="@android:color/transparent">

            <com.google.android.material.appbar.CollapsingToolbarLayout
                android:id="@+id/collapsingToolbar"
                android:layout_width="match_parent"
                android:layout_height="248dp"
                app:layout_scrollFlags="scroll|exitUntilCollapsed"
                app:contentScrim="@android:color/transparent">

                <ImageView
                    android:id="@+id/shop_image"
                    android:layout_width="match_parent"
                    android:layout_height="248dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/img_example"
                    android:fitsSystemWindows="true"
                    app:layout_collapseMode="parallax"
                    android:layout_marginTop="56dp" />

                <LinearLayout
                    android:id="@+id/chipVisitService"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:background="@drawable/bg_home_list_move"
                    android:clipToPadding="false"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginTop="56dp"
                    android:layout_gravity="top|start">

                    <ImageView
                        android:id="@+id/imgVisit"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginStart="4.5dp"
                        android:layout_marginTop="7dp"
                        android:layout_marginEnd="4.5dp"
                        android:layout_marginBottom="7dp"
                        android:src="@drawable/ic_home_list_move" />

                    <TextView
                        android:id="@+id/tvVisit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2.5dp"
                        android:layout_marginEnd="4.5dp"
                        android:layout_marginBottom="2.5dp"
                        android:includeFontPadding="false"
                        android:text="방문서비스"
                        android:textColor="#FEFEFE"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/badge_available"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="18.5dp"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_shop_share">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="4dp"
                        android:layout_gravity="center_vertical"
                        android:src="@drawable/ic_share" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="공유하기"
                        android:gravity="center_vertical"
                        android:textColor="#222222"
                        android:textSize="14sp"
                        android:layout_marginEnd="12dp" />
                </LinearLayout>
            </com.google.android.material.appbar.CollapsingToolbarLayout>
        </com.google.android.material.appbar.AppBarLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvShopDetail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="0dp"
            android:layout_marginTop="0dp"
            app:layout_behavior="@string/appbar_scrolling_view_behavior" />

        <LinearLayout
            android:id="@+id/linearLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="16dp"
            android:paddingEnd="18dp"
            android:paddingBottom="16dp">

            <Button
                android:id="@+id/btnBook"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:backgroundTint="#FE6B6B"
                android:text="예약하기"
                android:textColor="@color/white"
                android:textSize="16sp"
                app:cornerRadius="8dp" />
        </LinearLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/white"
        android:elevation="4dp"
        android:paddingStart="18dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/shop_back"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_left_arrow" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/shop_home"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_home" />
    </LinearLayout>

</FrameLayout>