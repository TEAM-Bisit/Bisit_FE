<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_cancel"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardUseCompatPadding="true"
    app:cardElevation="2dp"
    android:backgroundTint="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="14dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="20dp">

        <TextView
            android:id="@+id/tv_cancel_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="취소 완료"
            android:textSize="14sp"
            android:textColor="@color/main_red"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_cancel_reserv_no"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="예약 번호 ABC456"
            android:textSize="13sp"
            android:textColor="#515965"
            android:layout_marginTop="6dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/outline_gray"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="12dp"/>

        <!-- 이미지 + 텍스트 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iv_cancel_thumb"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:scaleType="centerCrop"
                android:src="@drawable/img_reserve"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_cancel_shop"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="또다른헤어"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_gray"/>

                <TextView
                    android:id="@+id/tv_cancel_datetime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2025.09.09 오후 1시"
                    android:textSize="13sp"
                    android:textColor="@color/muted_gray"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:id="@+id/tv_cancel_service"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="펌 32,000원"
                    android:textSize="13sp"
                    android:textColor="@color/black"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_cancel_detail"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="4dp"
            android:text="상세보기"
            android:textSize="15sp"
            android:background="@drawable/bg_button_outline"
            android:textColor="@color/dark_gray" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
