<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:padding="24dp"
    tools:context=".ui.signUp.StoreInfoFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="매장 정보를 입력해주세요."
            android:textColor="@color/black"
            android:textSize="18sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="매장 이름"
            android:textColor="#515965"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/et_store_name"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_edit_box"
            android:hint="매장 이름을 입력해주세요."
            android:inputType="text"
            android:paddingHorizontal="12dp"
            android:textSize="14sp"
            android:maxLines="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="매장 연락처"
            android:textColor="#515965"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/et_store_contact"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_edit_box"
            android:hint="매장 연락처를 입력해주세요."
            android:inputType="phone"
            android:maxLength="13"
            android:paddingHorizontal="12dp"
            android:textSize="14sp"
            android:maxLines="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="매장 주소"
            android:textColor="#515965"
            android:textSize="13sp" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_search_address"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:background="@drawable/bg_button_verify_selector"
                android:backgroundTint="#F0F2F5"
                android:paddingHorizontal="16dp"
                android:stateListAnimator="@null"
                android:text="주소 검색"
                android:textColor="#515965"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <EditText
                android:id="@+id/et_address_main"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_edit_box"
                android:focusable="false"
                android:clickable="false"
                android:hint="건물, 지번 또는 도로명 검색"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:maxLines="1"
                app:layout_constraintEnd_toStartOf="@id/btn_search_address"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <EditText
            android:id="@+id/et_address_detail"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_edit_box"
            android:hint="상세 주소 입력"
            android:inputType="text"
            android:paddingHorizontal="12dp"
            android:textSize="14sp"
            android:maxLines="1" />

        <View
            android:layout_width="match_parent"
            android:layout_height="100dp" />

    </LinearLayout>
</ScrollView>