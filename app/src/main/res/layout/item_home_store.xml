<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="300dp"
    android:background="@drawable/bg_store_list_outline"
    android:paddingStart="18dp"
    android:paddingEnd="0dp"
    android:paddingTop="28dp">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/imgRecycler"
        android:layout_width="0dp"
        android:layout_height="140dp"
        android:orientation="horizontal"
        android:overScrollMode="never"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="상호명"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#222222"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/imgRecycler"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="카테고리"
        android:textSize="13sp"
        android:textColor="#6D7583"
        android:layout_marginTop="8dp"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toBottomOf="@id/imgRecycler"
        app:layout_constraintBottom_toBottomOf="@id/tvName"
        app:layout_constraintStart_toEndOf="@+id/tvName"/>

    <LinearLayout
        android:id="@+id/linearRating"
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4.5dp"
        app:layout_constraintTop_toBottomOf="@id/tvCategory"
        app:layout_constraintStart_toStartOf="parent"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/imgStar"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_home_star"
            android:layout_marginEnd="3dp" />

        <TextView
            android:id="@+id/tvRating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4.9"
            android:textColor="#222222"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvReviewCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="(12)"
            android:textSize="13sp"
            android:textColor="#515965"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/linearOpenStatus"
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/linearRating"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/imgOpenStatus"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_open"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/tvOpenStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="영업중"
            android:textSize="13sp"
            android:textColor="#333333"/>

        <TextView
            android:id="@+id/tvBusinessHours"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" 09:00 ~ 18:00"
            android:textSize="13sp"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/chipGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/linearOpenStatus"
        app:layout_constraintStart_toStartOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>