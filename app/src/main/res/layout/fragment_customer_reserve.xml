<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/customerReserveFragment"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingVertical="12dp"
        android:paddingHorizontal="16dp"
        android:background="@color/white"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_left_arrow"
                android:contentDescription="뒤로가기" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="네일네일"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#222222"
                android:layout_marginStart="12dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:weightSum="4">

            <View
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="4dp"
                android:background="#FE6B6B"
                android:layout_marginHorizontal="4dp" />

            <View
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="4dp"
                android:background="#FE6B6B"
                android:layout_marginHorizontal="4dp" />

            <View
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="4dp"
                android:background="#FE6B6B"
                android:layout_marginHorizontal="4dp" />

            <View
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="4dp"
                android:background="#DDDDDD"
                android:layout_marginHorizontal="4dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 본문 스크롤 -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="80dp"
        android:layout_marginTop="84dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:text="케이트 원장"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#222222" />

                    <TextView
                        android:text="최근 시술 7회"
                        android:textSize="13sp"
                        android:textColor="#888888" />
                </LinearLayout>

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/sample_profile"
                    android:scaleType="centerCrop"
                    android:background="@drawable/circle_clip" />
            </LinearLayout>

            <!-- 안내문 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="8dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_info"
                    android:tint="#666666"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="디자이너 한 마디\n안녕하세요 장미헤어 원장 케이트입니다.\n예약에 앞서 다음 사항을 확인해주세요.\n안내사항안내사항안내사항"
                    android:textSize="13sp"
                    android:textColor="#666666" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="시술 받으실 날짜와 시간을 선택해주세요."
                android:textStyle="bold"
                android:textColor="#222222"
                android:textSize="15sp"
                android:layout_marginBottom="8dp" />

            <CalendarView
                android:id="@+id/calendarView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="24dp">

                <Button
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="10:00"
                    android:textSize="13sp"
                    android:backgroundTint="#F1F1F1"
                    android:textColor="#444444" />

                <Space
                    android:layout_width="8dp"
                    android:layout_height="match_parent" />

                <Button
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="10:30"
                    android:textSize="13sp"
                    android:backgroundTint="#222222"
                    android:textColor="@color/white" />
            </LinearLayout>

            <!-- 시술 메뉴 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="시술 메뉴를 선택해주세요."
                android:textStyle="bold"
                android:textColor="#222222"
                android:textSize="15sp"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvServiceMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="24dp" />

            <!-- 이용 방식 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="시술을 이용하실 방법을 알려주세요."
                android:textStyle="bold"
                android:textColor="#222222"
                android:textSize="15sp"
                android:layout_marginBottom="8dp" />

            <RadioGroup
                android:id="@+id/rgVisitType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbHomeService"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="방문 서비스\n디자이너가 고객님께 방문하여 프리미엄 서비스를 제공합니다."
                    android:textSize="13sp"
                    android:textColor="#444444"
                    android:padding="12dp" />

                <RadioButton
                    android:id="@+id/rbDirectVisit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="매장 서비스\n고객님이 매장에 직접 방문합니다."
                    android:textSize="13sp"
                    android:textColor="#444444"
                    android:padding="12dp" />
            </RadioGroup>
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNextStep"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="다음 단계"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:layout_gravity="bottom"
        app:cornerRadius="8dp"
        android:backgroundTint="#FE6B6B"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="20dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
