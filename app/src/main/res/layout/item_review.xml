<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingVertical="24dp"
    android:background="@drawable/ripple_rect"
    android:layout_marginBottom="8dp">

    <!-- 방문일자 + 메뉴 버튼 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvVisitDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2025.09.12, 금 방문"
            android:textColor="#6D7583"
            android:textSize="13sp" />

        <Space
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/btnMore"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_menu_dots"
            android:contentDescription="더보기" />
    </LinearLayout>

    <!-- 서비스명 -->
    <TextView
        android:id="@+id/tvServiceName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="서비스명 열펌"
        android:textColor="#666666"
        android:textSize="14sp" />

    <!-- 고객명 -->
    <TextView
        android:id="@+id/tvCustomerName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="고객명 김*영"
        android:textColor="#666666"
        android:textSize="14sp" />

    <LinearLayout
        android:id="@+id/layoutStars"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/star1"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_star_filled"
            android:layout_marginEnd="2dp" />

        <ImageView
            android:id="@+id/star2"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_star_filled"
            android:layout_marginEnd="2dp" />

        <ImageView
            android:id="@+id/star3"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_star_filled"
            android:layout_marginEnd="2dp" />

        <ImageView
            android:id="@+id/star4"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_star_filled"
            android:layout_marginEnd="2dp" />

        <ImageView
            android:id="@+id/star5"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_star_empty" />
    </LinearLayout>

    <!-- 리뷰 내용 -->
    <TextView
        android:id="@+id/tvReviewContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="마음에 쏙 들어요! 선생님도 친절하셔서 기분 좋게 시술 받았습니다^^"
        android:textColor="#222222"
        android:textSize="14sp" />
</LinearLayout>
