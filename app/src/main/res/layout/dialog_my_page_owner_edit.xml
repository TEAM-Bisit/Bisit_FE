<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@drawable/bg_card_white"
    android:padding="15dp"
    android:layout_marginHorizontal="18dp">

    <TextView
        android:id="@+id/tvMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="예약 시 고객님들에 노출돼요"
        android:textColor="#222222"
        android:textStyle="bold"
        android:textSize="16sp"
        android:layout_marginTop="17dp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvMessage2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="이 점 제대로 확인하셨나요?"
        android:textColor="#515965"
        android:textSize="14sp"
        android:layout_marginBottom="20dp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnClose"
            android:layout_width="142dp"
            android:layout_height="48dp"
            android:text="닫기"
            android:textColor="#515965"
            android:textSize="14sp"
            android:background="@drawable/bg_button_gray_light"
            android:stateListAnimator="@null"
            android:gravity="center"
            android:enabled="true"
            android:layout_marginEnd="10dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnWrite"
            android:layout_width="142dp"
            android:layout_height="48dp"
            android:text="사진 등록하기"
            android:textColor="#FEFEFE"
            android:textSize="14sp"
            android:background="@drawable/bg_button_blue_light"
            android:stateListAnimator="@null"
            android:gravity="center"
            android:enabled="true" />
    </LinearLayout>



</LinearLayout>
