<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/reviewCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    android:layout_marginBottom="12dp"
    android:layout_marginStart="18dp"
    android:layout_marginEnd="18dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="#E6EAF0"
    app:strokeWidth="1dp"
    android:backgroundTint="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginEnd="12dp">

                <TextView
                    android:id="@+id/labelService"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="서비스명"
                    android:textSize="12sp"
                    android:textColor="#9AA0A7" />

                <TextView
                    android:id="@+id/labelManager"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="담당"
                    android:textSize="12sp"
                    android:textColor="#9AA0A7"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/labelRate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="별점"
                    android:textSize="12sp"
                    android:textColor="#9AA0A7"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvServiceName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="모니터 수리"
                    android:textSize="14sp"
                    android:textColor="#222222"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvManager"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="우리 컴퓨터 사장님"
                    android:textSize="13sp"
                    android:textColor="#222222"
                    android:layout_marginTop="6dp" />

                <LinearLayout
                    android:id="@+id/starRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_home_star"
                        android:contentDescription="별" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_home_star"
                        android:contentDescription="별" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_home_star"
                        android:contentDescription="별" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_home_star"
                        android:contentDescription="별" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_home_star"
                        android:contentDescription="별" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvReviewContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="아이맥도 잘 고쳐주시네요.. 방문해주셔서 덕분에 잘 사용중입니다. ㅠㅠ"
            android:textSize="13sp"
            android:textColor="#333333"
            android:layout_marginTop="12dp" />

        <LinearLayout
            android:id="@+id/reviewFooterRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/tvReviewDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2025.09.12.금 방문"
                android:textSize="12sp"
                android:textColor="#9AA0A7" />

            <TextView
                android:id="@+id/reviewDot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  ·  "
                android:textSize="12sp"
                android:textColor="#9AA0A7" />

            <TextView
                android:id="@+id/tvReviewer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="김*희"
                android:textSize="12sp"
                android:textColor="#9AA0A7" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>