<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_dialog_white"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- 상단 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="19dp">

        <TextView
            android:text="매장 정보 수정"
            android:textColor="#222222"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <View
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="match_parent" />

        <ImageView
            android:id="@+id/btnClose"
            android:src="@drawable/ic_close_button"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:contentDescription="닫기" />
    </LinearLayout>

    <!-- 매장 이름 -->
    <TextView
        android:text="매장 이름"
        android:textColor="#515965"
        android:textSize="14sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etName"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="매장 이름을 입력해주세요."
        android:paddingHorizontal="12dp"
        android:background="@drawable/bg_edit_box"
        android:textColor="#222222"
        android:textColorHint="#9AA1AF"
        android:textSize="14sp" />

    <!-- 전화번호 -->
    <TextView
        android:text="전화번호"
        android:textColor="#515965"
        android:textSize="14sp"
        android:layout_marginTop="20dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etPhone"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="010-0000-0000"
        android:inputType="phone"
        android:paddingHorizontal="12dp"
        android:background="@drawable/bg_edit_box"
        android:textColor="#222222"
        android:textColorHint="#9AA1AF"
        android:textSize="14sp" />

    <!-- 주소 -->
    <TextView
        android:text="매장 주소"
        android:textColor="#515965"
        android:textSize="14sp"
        android:layout_marginTop="20dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/etAddr"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:hint="건물명, 도로명 또는 지번 검색"
            android:paddingHorizontal="12dp"
            android:background="@drawable/bg_edit_box"
            android:textColor="#222222"
            android:textColorHint="#9AA1AF"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btnSearchAddr"
            android:layout_width="96dp"
            android:layout_height="48dp"
            android:layout_marginStart="4dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="주소 검색"
            android:textColor="#515965"
            android:textStyle="normal"
            android:background="@drawable/bg_btn_search_addr" />
    </LinearLayout>

    <EditText
        android:id="@+id/etAddrDetail"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:hint="상세 주소 입력"
        android:paddingHorizontal="12dp"
        android:background="@drawable/bg_edit_box"
        android:textColor="#222222"
        android:textColorHint="#9AA1AF"
        android:textSize="14sp" />

    <!-- 저장 버튼 -->
    <TextView
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:text="저장하기"
        android:textStyle="bold"
        android:textColor="@color/btn_primary_text_selector"
        android:background="@drawable/bg_btn_primary_selector" />

</LinearLayout>
