<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:padding="18dp"
    tools:context=".ui.signUp.StoreIntroFragment"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="매장 소개를 입력해주세요."
            android:textColor="@color/black"
            android:textSize="18sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="한줄소개"
            android:textColor="#515965"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/et_store_intro"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_edit_box"
            android:hint="한 줄 소개를 입력해주세요."
            android:inputType="text"
            android:paddingHorizontal="12dp"
            android:textSize="14sp"
            android:maxLines="1" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:background="#F4F4F4" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="대표사진"
                android:textColor="#515965"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="최대 5장"
                android:textColor="#999999"
                android:textSize="13sp" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_store_images"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_store_image_add" /> <LinearLayout
        android:id="@+id/layout_image_guide"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_question_mark_gray"
            app:tint="#999999" />

        <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_weight="1"
        android:text="고객님이 매장 리스트에서 볼 수 있는 이미지입니다."
        android:textColor="#777777"
        android:textSize="12sp" />

        <ImageView
            android:id="@+id/iv_guide_arrow"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_arrow_down_gray" />
    </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:background="#F4F4F4" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="제공하는 서비스"
            android:textColor="#515965"
            android:textSize="13sp" />

        <RadioGroup
            android:id="@+id/rg_service_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <RadioButton
                android:id="@+id/rb_visit_service"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:buttonTint="@color/selector_radio_button"
                android:paddingStart="8dp"
                android:text="방문 서비스"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@android:color/transparent"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="40dp"
                android:layout_marginBottom="12dp"
                android:text="디자이너가 고객님께 방문하여 프리미엄 서비스를 제공합니다"
                android:textColor="#6D7583"
                android:textSize="13sp" />

            <RadioButton
                android:id="@+id/rb_shop_service"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:buttonTint="@color/selector_radio_button"
                android:paddingStart="8dp"
                android:text="매장 서비스"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@android:color/transparent"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="40dp"
                android:layout_marginBottom="12dp"
                android:text="고객님이 매장에 직접 방문합니다."
                android:textColor="#6D7583"
                android:textSize="13sp" />

        </RadioGroup>

    </LinearLayout>
</ScrollView>