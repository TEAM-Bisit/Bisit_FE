<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_wait"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardUseCompatPadding="true"
    app:cardElevation="2dp"
    android:backgroundTint="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tv_wait_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="예약확인중"
            android:textSize="14sp"
            android:textColor="@color/muted_gray"/>

        <TextView
            android:id="@+id/tv_wait_reserv_no"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="예약 번호  dPdirghkrdlswnddqlslek"
            android:textSize="13sp"
            android:textColor="#515965"
            android:layout_marginTop="6dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/outline_gray"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="12dp"/>

        <!-- 이미지 + 텍스트 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iv_wait_thumb"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:scaleType="centerCrop"
                android:src="@drawable/img_reserve"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_wait_shop"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="우리컴퓨터"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_gray"/>

                <TextView
                    android:id="@+id/tv_wait_datetime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2025.09.09 오후 1시"
                    android:textSize="13sp"
                    android:textColor="@color/muted_gray"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:id="@+id/tv_wait_service"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="매니큐어  25,000원"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp">
                </TextView>
            </LinearLayout>
        </LinearLayout>

        <!-- 버튼 그룹 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="14dp"
            android:gravity="end">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_wait_inquire"
                android:layout_width="160dp"
                android:layout_height="44dp"
                android:layout_marginEnd="8dp"
                android:text="문의하기"
                android:textSize="15sp"
                android:background="@drawable/bg_button_outline"
                android:textColor="@color/dark_gray" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_wait_cancel"
                android:layout_width="160dp"
                android:layout_height="44dp"
                android:text="취소하기"
                android:textSize="15sp"
                android:background="@drawable/bg_button_gray_rounded" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
