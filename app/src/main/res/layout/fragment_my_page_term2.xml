<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_term2"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="개인정보 처리방침"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EAEAEA" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/term1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="수집 항목"
                android:textColor="#222222"
                android:textStyle="bold"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"/>

            <TextView
                android:id="@+id/term1_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="이름, 연락처, 이메일, 위치정보, 예약 내역, 결제 정보"
                android:textColor="#515965"
                android:textSize="12sp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:id="@+id/term1_title2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="수집 목적"
                android:textColor="#222222"
                android:textStyle="bold"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"/>

            <TextView
                android:id="@+id/term1_content2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="예약 관리, 고객 상담, 위치 기반 매칭, 결제 처리."
                android:textColor="#515965"
                android:textSize="12sp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:id="@+id/term1_title3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="보관 기간"
                android:textColor="#222222"
                android:textStyle="bold"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"/>

            <TextView
                android:id="@+id/term1_content3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="회원 탈퇴 시 30일 뒤 파기 (단, 신청 시 관련 법령에 따라 5년 보관할\n수 있음)."
                android:textColor="#515965"
                android:textSize="12sp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:id="@+id/term1_title4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="제 3자 제공"
                android:textColor="#222222"
                android:textStyle="bold"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"/>

            <TextView
                android:id="@+id/term1_content4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="결제 대행사, 제휴 매장(예약 확정 시 고객 연락처 제공)."
                android:textColor="#515965"
                android:textSize="12sp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:id="@+id/term1_title5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="위탁 처리"
                android:textColor="#222222"
                android:textStyle="bold"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"/>

            <TextView
                android:id="@+id/term1_content5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="결제, 문자 발송, 클라우드 서버 운영."
                android:textColor="#515965"
                android:textSize="12sp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:id="@+id/term1_title6"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="이용자의 권리"
                android:textColor="#222222"
                android:textStyle="bold"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"/>

            <TextView
                android:id="@+id/term1_content6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="개인정보 열람/수정/삭제/동의 철회 가능."
                android:textColor="#515965"
                android:textSize="12sp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:id="@+id/term1_title7"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="개인정보 보호책임자"
                android:textColor="#222222"
                android:textStyle="bold"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"/>

            <TextView
                android:id="@+id/term1_content7"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="이름 / 이메일 / 전화번호."
                android:textColor="#515965"
                android:textSize="12sp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
