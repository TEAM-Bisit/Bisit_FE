<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_left_arrow" 
            android:contentDescription="뒤로가기"/>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <ImageView
            android:id="@+id/btnHome"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_home"
            android:contentDescription="홈으로"/>
    </LinearLayout>

    <!-- Sorting Chips -->
    <HorizontalScrollView
        android:id="@+id/scrollSort"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="12dp">

            <TextView
                android:id="@+id/sortHighRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="별점 높은순"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_sort_chip_selected"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/sortLowRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="별점 낮은순"
                android:textSize="13sp"
                android:textColor="#555555"
                android:background="@drawable/bg_sort_chip_unselected"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/sortRecent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="최신순"
                android:textSize="13sp"
                android:textColor="#555555"
                android:background="@drawable/bg_sort_chip_unselected"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Review List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMoreReviews"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp" 
        app:layout_constraintTop_toBottomOf="@id/scrollSort"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:listitem="@layout/item_shop_review"/>

    <!-- Bottom Reserve Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnReserve"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:text="예약하기"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="8dp"
        android:backgroundTint="#4076FF"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
