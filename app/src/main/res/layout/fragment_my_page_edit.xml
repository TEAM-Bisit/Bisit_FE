<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:layout_marginTop="14dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="18dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="내 정보 수정"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EAEAEA" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="이름"
        android:textSize="14sp"
        android:layout_marginTop="20dp"
        android:layout_marginStart="18dp"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/et_name"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_edittext"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:paddingStart="14dp"
        android:text="김비짓" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="이메일"
        android:textSize="14sp"
        android:layout_marginTop="20dp"
        android:layout_marginStart="18dp"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/et_email"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_edittext"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:paddingStart="14dp"
        android:text="bisitbisit123@naver.com" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="연락처"
        android:textSize="14sp"
        android:layout_marginTop="20dp"
        android:layout_marginStart="18dp"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/et_phone"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:background="@drawable/bg_edittext"
            android:layout_marginStart="18dp"
            android:paddingStart="14dp"
            android:hint="010-0000-0000" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_verify"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="18dp"
            android:text="번호 인증"
            android:enabled="false"
            android:textColor="@color/text_my_page_phone_selector"
            android:background="@drawable/bg_my_page_phone_selector"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <EditText
            android:id="@+id/et_phone2"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:background="@drawable/bg_edittext"
            android:layout_marginStart="18dp"
            android:paddingStart="14dp"
            android:visibility="gone"
            android:hint="인증 번호 입력"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_verify2"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="18dp"
            android:text="완료"
            android:visibility="gone"
            android:enabled="false"
            android:textColor="@color/text_my_page_phone_selector"
            android:background="@drawable/bg_my_page_phone_selector"/>
    </LinearLayout>
</LinearLayout>
